{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "serve (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "."],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "live-server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=8080"],
      "port": 8080
    }
  ]
}
